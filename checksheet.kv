<RootWidget>:
    orientation: 'vertical'
    
    # 리스트 화면 (메인)
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0.15, 0.15, 0.15, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # 상단 메뉴바
        BoxLayout:
            size_hint_y: None
            height: '60dp'
            padding: '5dp'
            spacing: '5dp'
            canvas.before:
                Color:
                    rgba: 0.2, 0.2, 0.2, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: '설정'
                size_hint_x: 0.2
                on_release: app.open_smb_settings()
            Button:
                text: '엑셀 선택'
                on_release: app.select_source('excel')
            Button:
                text: 'PDF 폴더'
                on_release: app.select_source('pdf')
            Button:
                text: '저장'
                background_color: 0.2, 0.7, 0.3, 1
                size_hint_x: 0.2
                on_release: app.save_to_excel()

        # 머릿글
        BoxLayout:
            size_hint_y: None
            height: '40dp'
            padding: [2, 0]
            canvas.before:
                Color:
                    rgba: 0.3, 0.3, 0.3, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: 'No'
                size_hint_x: 0.1
            Label:
                text: '품목코드'
                size_hint_x: 0.3
            Label:
                text: '수량'
                size_hint_x: 0.15
            Label:
                text: '완료'
                size_hint_x: 0.15
            Label:
                text: '부족'
                size_hint_x: 0.15
            Label:
                text: '재작업'
                size_hint_x: 0.15

        # 데이터 리스트
        CheckSheetRV:
            id: rv
            viewclass: 'RowWidget'
            RecycleBoxLayout:
                default_size: None, dp(56)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                spacing: '1dp'

    # --- 내장 PDF 뷰어 레이어 (조건부 노출) ---
    FloatLayout:
        size_hint: (1, 1) if app.viewer_visible else (0, 0)
        opacity: 1 if app.viewer_visible else 0
        pos_hint: {'x': 0, 'y': 0}
        
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: 'vertical'
            padding: dp(10)
            
            # 상단바 (품목명 및 닫기)
            BoxLayout:
                size_hint_y: None
                height: dp(60)
                spacing: dp(10)
                Label:
                    text: app.root.ids.rv.data[app.current_view_idx]['item_code'] if app.current_view_idx >= 0 else ""
                    font_size: '20sp'
                    bold: True
                Button:
                    text: 'X 닫기'
                    size_hint_x: None
                    width: dp(100)
                    on_release: app.close_viewer()

            # PDF 이미지 영역 (스와이프 감지)
            Image:
                id: pdf_img
                source: ""
                allow_stretch: True
                keep_ratio: True
                on_touch_down: app.on_viewer_touch_down(args[1])
                on_touch_up: app.on_viewer_touch_up(args[1])

            # 하단 상태 변경 버튼 (리스트와 연동)
            BoxLayout:
                size_hint_y: None
                height: dp(80)
                spacing: dp(10)
                padding: [0, dp(10)]
                
                Button:
                    text: '완료'
                    background_color: (0, 1, 0, 1) if (app.current_view_idx >= 0 and app.root.ids.rv.data[app.current_view_idx]['complete']) else (0.3, 0.3, 0.3, 1)
                    on_release: app.update_item_status(app.root.ids.rv.data[app.current_view_idx]['item_code'], app.root.ids.rv.data[app.current_view_idx]['no'], 'complete')
                Button:
                    text: '부족'
                    background_color: (1, 1, 0, 1) if (app.current_view_idx >= 0 and app.root.ids.rv.data[app.current_view_idx]['shortage']) else (0.3, 0.3, 0.3, 1)
                    on_release: app.update_item_status(app.root.ids.rv.data[app.current_view_idx]['item_code'], app.root.ids.rv.data[app.current_view_idx]['no'], 'shortage')
                Button:
                    text: '재작업'
                    background_color: (1, 0, 0, 1) if (app.current_view_idx >= 0 and app.root.ids.rv.data[app.current_view_idx]['rework']) else (0.3, 0.3, 0.3, 1)
                    on_release: app.update_item_status(app.root.ids.rv.data[app.current_view_idx]['item_code'], app.root.ids.rv.data[app.current_view_idx]['no'], 'rework')

<RowWidget>:
    orientation: 'horizontal'
    padding: [5, 2]
    canvas.before:
        Color:
            rgba: 0.25, 0.25, 0.25, 1
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: root.no
        size_hint_x: 0.1
    
    Button:
        text: root.item_code
        size_hint_x: 0.3
        background_normal: ''
        background_color: 0.2, 0.4, 0.6, 1
        on_release: root.open_pdf()
        shorten: True
        shorten_from: 'right'

    Label:
        text: root.quantity
        size_hint_x: 0.15

    Button:
        text: 'V' if root.complete else ''
        size_hint_x: 0.15
        font_size: '20sp'
        background_normal: ''
        background_color: (0, 1, 0, 0.5) if root.complete else (0.4, 0.4, 0.4, 1)
        on_release: root.on_checkbox_active('complete')

    Button:
        text: 'V' if root.shortage else ''
        size_hint_x: 0.15
        font_size: '20sp'
        background_normal: ''
        background_color: (1, 1, 0, 0.5) if root.shortage else (0.4, 0.4, 0.4, 1)
        on_release: root.on_checkbox_active('shortage')

    Button:
        text: 'V' if root.rework else ''
        size_hint_x: 0.15
        font_size: '20sp'
        background_normal: ''
        background_color: (1, 0, 0, 0.5) if root.rework else (0.4, 0.4, 0.4, 1)
        on_release: root.on_checkbox_active('rework')
